{
  "name": "squidgame100-minecraft",
  "version": "0.1.0",
  "private": true,
  "description": "SquidGame100 MineCraft — a 100-player, permadeath, Squid Game–themed voxel battle-royale in the browser.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/shared",
    "packages/client",
    "packages/server"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm -w @sg100/shared run build && npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:client": "npm -w @sg100/client run dev",
    "dev:server": "npm -w @sg100/server run dev",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "playwright": "^1.61.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
